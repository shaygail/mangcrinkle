{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Mang Crinkle menu products (mirrors Next.js Product type)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "productId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "crinkle-standard",
        "crinkle-premium",
        "crinkle-signature",
        "crinkle-pack",
        "lava",
        "hot-drink",
        "iced-drink"
      ],
      "required": true
    },
    "tier": {
      "type": "string"
    },
    "badge": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
